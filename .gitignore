# 虛擬環境
venv/
.venv/
env/

# Python 快取
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/

# 產物與中繼檔(每支影片跑出來的東西,不進版控)
output/
*.mp4
*.wav
*.srt
*.xml
# 但 Premiere 面板的設定檔要保留(上面的 *.xml 會誤傷)
!premiere-panel/**/*.xml

# 轉錄快取
*_transcript.json

# Whisper 下載的模型(很大,各自下載)
*.bin
models/

# 作業系統雜項
.DS_Store
Thumbs.db

# 編輯器
.vscode/
.idea/
*.swp

# 個人設定覆寫(不進版控,保留你自己的門檻/詞表/VST 路徑)
config/settings_local.py
config/settings_local.json
# VST 調好的參數狀態(個人、二進位,不進版控)
config/vst_state/

# 面板的個人路徑設定(安裝程式產生,不進版控)
config/panel.json

# 打包出來的發佈檔(不進版控)
dist/
