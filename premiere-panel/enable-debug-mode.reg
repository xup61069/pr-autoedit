Windows Registry Editor Version 5.00

; Allow Premiere to load unsigned self-made panels (developer mode).
; Run once. Covers CEP 10/11/12 for different Premiere versions.

[HKEY_CURRENT_USER\Software\Adobe\CSXS.10]
"PlayerDebugMode"="1"

[HKEY_CURRENT_USER\Software\Adobe\CSXS.11]
"PlayerDebugMode"="1"

[HKEY_CURRENT_USER\Software\Adobe\CSXS.12]
"PlayerDebugMode"="1"
