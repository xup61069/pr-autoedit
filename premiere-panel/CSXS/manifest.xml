<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="9.0" ExtensionBundleId="com.prautoedit.panel"
    ExtensionBundleVersion="1.2.0" ExtensionBundleName="PR AutoEdit"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <ExtensionList>
    <Extension Id="com.prautoedit.panel" Version="1.2.0"/>
  </ExtensionList>
  <ExecutionEnvironment>
    <HostList>
      <!-- PPRO = Premiere Pro;版本範圍涵蓋 2024~未來 -->
      <Host Name="PPRO" Version="[24.0,99.9]"/>
    </HostList>
    <LocaleList>
      <Locale Code="All"/>
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="9.0"/>
    </RequiredRuntimeList>
  </ExecutionEnvironment>
  <DispatchInfoList>
    <Extension Id="com.prautoedit.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./index.html</MainPath>
          <ScriptPath>./jsx/host.jsx</ScriptPath>
          <!-- 啟用 Node.js,面板才能啟動本地 Python -->
          <CEFCommandLine>
            <Parameter>--enable-nodejs</Parameter>
            <Parameter>--mixed-context</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>PR剪教學一條龍</Menu>
          <Geometry>
            <Size><Height>460</Height><Width>340</Width></Size>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
